# Virtual environment
venv_credit_chatbot/

# ChromaDB — generated, rebuild locally by running src/ingest.py
chroma_db/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# macOS
.DS_Store

# Environment variables — contains KB_ENCRYPTION_KEY, never commit
.env

# Decrypted KB files — only .enc versions go in the repo
knowledge_base/07_score_patterns.md
knowledge_base/08_bureau_parameters.md
knowledge_base/data_dictionary/*.pdf

# Notebook outputs
notebooks/*.csv
notebooks/*.png

# Scrub data — sensitive, never commit
scrub_data/

# Encrypted customer DB — contains real bureau data, never commit
data/*
# Allow plain reference DB — no PII, safe to commit
!data/score_drivers.db
